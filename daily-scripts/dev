#!/usr/bin/env bash

loading() {
  echo -ne "\rоёҶ Loading"
  sleep 0.25
  echo -ne "\rоёҮ Loading"
  sleep 0.25
  echo -ne "\rоёҲ Loading"
  sleep 0.25
  echo -ne "\rоёү Loading"
  sleep 0.25
  echo -ne "\rоёҠ Loading"
  sleep 0.25
  echo -ne "\rоёӢ Loading"
  echo -ne "\r\033[2K"
}

sff="пҒ» Site Folder Files пҒЎ"
gs="оңӮ Git Status пҒЎ"
lc="у°ңҳ Last Commit пҒЎ"

for dev in "$@"; do
  case "$dev" in
  "-project site")
    loading
    echo "$sff"
    ls ~/anom/
    echo
    echo "$gs"
    git -C ~/anom status
    echo
    echo "$lc"
    git -C ~/anom log --oneline -1
    ;;
  esac
done
